{
  "name": "relatorio-maker",
  "private": true,
  "version": "1.0.0",
  "description": "Gerador de Relatórios Médicos e LME",
  "author": "Guilherme Tayar",
  "type": "commonjs",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "npm run build && electron-builder --win",
    "electron:linux": "npm run build && electron-builder --linux",
    "electron:pack": "electron-builder --dir"
  },
  "build": {
    "appId": "com.meddoc.relatoriomaker",
    "productName": "Relatorio Maker",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/assets/template-logo-2.png"
    },
    "linux": {
      "target": [
        "deb",
        "rpm",
        "AppImage"
      ],
      "maintainer": "Guilherme Tayar <guilhermetayar@gmail.com>",
      "category": "Office",
      "icon": "public/assets/template-logo-2.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Relatorio Maker"
    }
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "docx": "^9.5.0",
    "file-saver": "^2.0.5",
    "jspdf": "^3.0.1",
    "lucide-react": "^0.511.0",
    "pdf-lib": "^1.17.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.2.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.5",
    "@types/file-saver": "^2.0.7",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.1.5",
    "typescript": "~5.8.3",
    "vite": "^6.3.3",
    "wait-on": "^9.0.5"
  }
}
